{
  "name": "amazon-clone-backend",
  "version": "1.0.0",
  "description": "Express.js and Prisma backend for the Amazon Clone web application",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "postinstall": "prisma generate",
