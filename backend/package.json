    "prisma:migrate": "prisma migrate dev",
    "db:seed": "node src/seed/seedProducts.js"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nodemailer": "^8.0.7",
    "prisma": "^5.12.1",
    "stripe": "^15.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
